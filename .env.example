# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# --------------------------------------------------------------------------
# Anthropic — only external API key required
# Used for: claude-3-5-haiku-20241022 (LLM)
# Embeddings use local sentence-transformers (BAAI/bge-small-en-v1.5, 384 dims)
# — no additional API key needed.
# --------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --------------------------------------------------------------------------
# Actian VectorAI DB
# Local default is localhost:6574 (gRPC).
# When running via docker-compose this is overridden to vectorai-db:6574.
# On Render it is set to vectorai-db:6574 by the render.yaml blueprint.
# --------------------------------------------------------------------------
VECTORAI_DB_URL=localhost:6574

# --------------------------------------------------------------------------
# Scalekit
# Get these from: Scalekit dashboard → Developers → Settings → API Credentials
# --------------------------------------------------------------------------
SCALEKIT_ENV_URL=https://your-env.scalekit.com
SCALEKIT_CLIENT_ID=skc_...
SCALEKIT_CLIENT_SECRET=sks_...

# Connector slug — must exactly match the connection name in your Scalekit
# dashboard (e.g. "github", "gmail", "slack").
SCALEKIT_CONNECTION_NAME=github

# --------------------------------------------------------------------------
# Scalekit Virtual MCP Server (optional — required for the MCP tool path)
# Populate these by running: python agent-app/setup_mcp.py
# If absent, agent-app falls back to the direct LangChain adapter path.
# --------------------------------------------------------------------------
SCALEKIT_MCP_CONFIG_ID=
SCALEKIT_MCP_SERVER_URL=
